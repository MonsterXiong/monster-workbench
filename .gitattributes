# Default to LF for all text files. This keeps Windows global autocrlf settings
# from rewriting project files on checkout or add.
* text=auto eol=lf

# Windows-only scripts should remain CRLF for cmd.exe / Windows tooling.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.bmp binary
*.tif binary
*.tiff binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.db binary
*.sqlite binary
*.sqlite3 binary
