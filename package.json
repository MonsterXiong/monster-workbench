{
  "name": "monster-tools",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "npm run tauri:dev",
    "check:architecture": "node scripts/check-architecture.js",
    "test:ai-sidecar": "python src-tauri/sidecars/python/test_ai_provider_tester.py",
    "test:ai-sidecar:stress": "python src-tauri/sidecars/python/stress_ai_provider_tester.py",
    "smoke:real-image-edit": "python scripts/smoke-real-provider-image-edit.py",
    "check:commit-message": "node scripts/check-commit-message.js --latest",
    "docs:generate": "node scripts/generate-utils-docs.cjs && npm run check:utils-docs",
    "check:utils-docs": "npm run check:utils-docs:quality && npm run check:utils-docs:sandbox",
    "check:utils-docs:quality": "node scripts/check-utils-docs-quality.cjs",
    "check:utils-docs:sandbox": "node scripts/check-utils-docs-sandbox.cjs",
    "mock:sync-config": "node scripts/sync-browser-mock-config.cjs",
    "setup:git-hooks": "git config core.hooksPath .githooks",
    "prepare": "npm run setup:git-hooks",
    "typecheck": "vue-tsc --noEmit",
    "verify": "npm run check:architecture && npm run check:utils-docs && npm run typecheck",
    "prebuild": "npm run typecheck",
    "build": "npm run build:frontend",
    "build:frontend": "npm run sync-version && vite build",
    "build:staging": "npm run sync-version && vite build --mode staging",
    "build:production": "npm run build",
    "preview": "vite preview",
    "pretauri:dev": "npm run typecheck",
    "tauri:dev": "node scripts/tauri-dev.cjs",
    "tauri:build:no-bundle": "npx tauri build --no-bundle",
    "tauri:build:full": "npx tauri build",
    "pretauri": "npm run typecheck",
    "tauri": "node scripts/tauri.cjs",
    "sync-version": "node scripts/sync-version.js",
    "changelog": "node scripts/changelog.js",
    "release:test": "gh workflow run release.yml --ref main -f publish_release=false",
    "release:test:full": "gh workflow run release.yml --ref main -f publish_release=false -f full_bundle=true",
    "release:runs": "gh run list --workflow release.yml --limit 5",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "blueimp-md5": "^2.19.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "element-plus": "^2.14.1",
    "jsqr": "^1.4.0",
    "lucide-vue-next": "^0.562.0",
    "otpauth": "^9.5.0",
    "otplib": "^13.4.0",
    "pinia": "^3",
    "splitpanes": "^4.1.2",
    "tailwind-merge": "^3.4.0",
    "vue": "^3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/blueimp-md5": "^2.18.2",
    "@types/otplib": "^7.0.0",
    "@vitejs/plugin-vue": "^6",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^28.0.0",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.0.4",
    "vue-tsc": "^3"
  }
}
