{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monster Tools",
  "version": "0.0.5",
  "identifier": "com.monster.tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; media-src 'self' asset: http://asset.localhost https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.monster-tools/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../src/config/ai-provider-registry.json",
      "sidecars/python/ai_provider_actions.py",
      "sidecars/python/ai_provider_artifacts.py",
      "sidecars/python/ai_provider_input.py",
      "sidecars/python/ai_provider_results.py",
      "sidecars/python/ai_provider_tester.py",
      "sidecars/python/provider_anthropic_adapter.py",
      "sidecars/python/provider_adapters.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRERUQ0ODExMTYyMzQ3MjAKUldRZ1J5TVdFVWp0VFFXazk2YlEzWHJzTXFUNGcyZUNoOVp4YU94SkowSEg3RSs1NnhCeGtmcm4K",
      "endpoints": [
        "https://github.com/MonsterXiong/monster-workbench/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
